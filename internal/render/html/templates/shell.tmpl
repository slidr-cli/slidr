<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{.Meta.Title}}</title>
<style>
/* ---- reset ---- */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ---- theme (injected first so layout overrides win) ---- */
{{.ThemeCSS}}

/* ---- layout defaults (after theme -- higher cascade priority) ---- */
.grid { display: grid; gap: 16px; }
.grid.two { grid-template-columns: 1fr 1fr; }
.grid.four { grid-template-columns: repeat(4, 1fr); }

.card {
  border-radius: 8px;
  padding: 18px 20px;
}

.quote {
  border-left: 5px solid;
  padding-left: 20px;
}

.kicker { font-family: monospace; font-size: 18px; font-weight: 800; }
.speaker { font-size: 23px; font-weight: 750; }
.speaker span { display: block; font-size: 18px; font-weight: 500; }

table { border-collapse: collapse; width: 100%; }
th, td { padding: 10px 14px; text-align: left; vertical-align: top; }

footer {
  position: absolute;
  bottom: 20px;
  left: 64px;
  right: 64px;
}

/* ---- screen mode: one slide at a time, aspect-ratio constrained ---- */
@media screen {
  html, body {
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background: #111;
  }
  body > section {
    display: none !important;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    /* Scale to fit viewport, preserving {{.SlideW}}x{{.SlideH}} aspect. */
    width:  min(100vw, calc(100vh * {{.Ratio}}));
    height: min(100vh, calc(100vw / {{.Ratio}}));
    overflow: hidden;
  }
  body > section.active {
    display: block !important;
  }

  /* Title slide: center content block vertically.
     Override in theme CSS with stronger selector if needed. */
  .layout-title {
    display: flex !important;
    flex-direction: column;
    justify-content: center;
    min-height: 100%;
  }
}

/* ---- print mode: one slide per page ---- */
@media print {
  @page {
    margin: 0;
  }
  html, body {
    width: auto;
    height: auto;
    margin: 0;
    padding: 0;
    overflow: visible;
    background: none;
  }
  body > section {
    display: block !important;
    position: relative !important;
    top: auto !important;
    left: auto !important;
    transform: none !important;
    width: {{.SlideW}}px !important;
    height: {{.SlideH}}px !important;
    max-width: none !important;
    max-height: none !important;
    page-break-after: always;
    page-break-inside: avoid;
    overflow: hidden;
  }
  body > section:last-child {
    page-break-after: avoid;
  }
  #slidr-nav {
    display: none !important;
  }
}

/* ---- nav bar (screen only) ---- */
#slidr-nav {
  display: none;
}
@media screen {
  #slidr-nav {
    display: flex;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 36px;
    align-items: center;
    justify-content: center;
    gap: 16px;
    background: rgba(0,0,0,0.7);
    color: #aaa;
    font-family: system-ui, sans-serif;
    font-size: 14px;
    z-index: 1000;
    user-select: none;
  }
  #slidr-nav button {
    background: none;
    border: 1px solid #555;
    color: #ccc;
    padding: 3px 12px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
  }
  #slidr-nav button:hover {
    background: rgba(255,255,255,0.1);
    color: #fff;
  }
  #slidr-nav button:disabled {
    opacity: 0.3;
    cursor: default;
  }
  #slidr-nav span {
    min-width: 60px;
    text-align: center;
  }
}
</style>
</head>
<body>
{{.SlidesHTML}}

<div id="slidr-nav">
  <button id="slidr-prev" title="Previous (Left arrow)">&larr;</button>
  <span id="slidr-counter">1 / 1</span>
  <button id="slidr-next" title="Next (Right arrow)">&rarr;</button>
</div>

<script>
(function() {
  var slides = document.querySelectorAll('body > section');
  var total = slides.length;
  if (total === 0) return;
  var current = 0;
  var counter = document.getElementById('slidr-counter');
  var prevBtn = document.getElementById('slidr-prev');
  var nextBtn = document.getElementById('slidr-next');

  function show(n) {
    if (n < 0 || n >= total) return;
    slides[current].classList.remove('active');
    current = n;
    slides[current].classList.add('active');
    counter.textContent = (current + 1) + ' / ' + total;
    prevBtn.disabled = current === 0;
    nextBtn.disabled = current === total - 1;
  }

  show(0);

  prevBtn.addEventListener('click', function() { show(current - 1); });
  nextBtn.addEventListener('click', function() { show(current + 1); });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowLeft' || e.key === 'ArrowUp' || e.key === 'PageUp') {
      e.preventDefault(); show(current - 1);
    } else if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === 'PageDown' || e.key === ' ') {
      e.preventDefault(); show(current + 1);
    } else if (e.key === 'Home') {
      e.preventDefault(); show(0);
    } else if (e.key === 'End') {
      e.preventDefault(); show(total - 1);
    }
  });
})();
</script>
</body>
</html>
